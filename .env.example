TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DRY_RUN=true
COINS=ETH,SOL

# Polymarket CLOB API
POLY_API_KEY=your_api_key
POLY_API_SECRET=your_api_secret
POLY_PASSPHRASE=your_passphrase

# Polygon Network
RPC_URL=https://polygon-bor-rpc.publicnode.com
WALLET_ADDRESS=your_wallet_address

# Builder API (Gasless Redemption)
# Create at https://polymarket.com/settings?tab=builder
BUILDER_API_KEY=your_builder_key
BUILDER_SECRET=your_builder_secret
BUILDER_PASSPHRASE=your_builder_passphrase
RELAYER_URL=https://relayer-v2.polymarket.com
ENABLE_5M=true
ENABLE_15M=false
